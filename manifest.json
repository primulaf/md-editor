{
  "manifest_version": 3,
  "name": "Markdown 编辑器",
  "version": "1.0.0",
  "description": "离线 Markdown 编辑器，支持实时预览、深色模式、目录生成、图片粘贴与 HTML 导出",
  "action": {
    "default_title": "打开 Markdown 编辑器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
